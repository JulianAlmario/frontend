---
import Layout from '../layouts/Layout.astro';
import BooksGrid from '../components/BooksGrid.tsx';
---

<Layout title="Catálogo de Libros - Biblioteca Digital">
  <div class="py-20 px-4">
    <div class="max-w-7xl mx-auto">
      <!-- Header -->
      <div class="text-center mb-12">
        <h1 class="text-5xl md:text-6xl font-display font-bold text-white mb-4">
          Catálogo de Libros
        </h1>
        <p class="text-xl text-gray-300 max-w-3xl mx-auto">
          Explora nuestra colección completa de libros disponibles para reserva
        </p>
      </div>

      <!-- Books Grid Component -->
      <BooksGrid client:load showFilters={true} />
    </div>
  </div>
</Layout>

<script>
  // Search functionality
  const searchInput = document.getElementById('searchInput');
  const clearSearch = document.getElementById('clearSearch');
  const filterToggle = document.getElementById('filterToggle');
  const filterDropdown = document.getElementById('filterDropdown');
  const ratingFilter = document.getElementById('ratingFilter');
  const ratingValue = document.getElementById('ratingValue');
  const applyFilters = document.getElementById('applyFilters');
  const clearFilters = document.getElementById('clearFilters');
  const quickFilters = document.querySelectorAll('.quick-filter');
  const availabilityFilters = document.querySelectorAll('.filter-availability');

  // Show/hide clear search button
  searchInput?.addEventListener('input', function() {
    if ((this as HTMLInputElement).value.length > 0) {
      clearSearch?.classList.remove('hidden');
    } else {
      clearSearch?.classList.add('hidden');
    }
    // Filter books based on search
    filterBooks();
  });

  // Clear search
  clearSearch?.addEventListener('click', function() {
    (searchInput as HTMLInputElement).value = '';
    this.classList.add('hidden');
    filterBooks();
  });

  // Toggle filter dropdown
  filterToggle?.addEventListener('click', function(e) {
    e.stopPropagation();
    filterDropdown?.classList.toggle('hidden');
    const arrow = this.querySelector('svg');
    arrow?.classList.toggle('rotate-180');
  });

  // Close dropdown when clicking outside
  document.addEventListener('click', function(e) {
    if (!filterDropdown?.contains(e.target as Node) && e.target !== filterToggle) {
      filterDropdown?.classList.add('hidden');
      const arrow = filterToggle?.querySelector('svg');
      arrow?.classList.remove('rotate-180');
    }
  });

  // Rating filter
  ratingFilter?.addEventListener('input', function() {
    if (ratingValue) ratingValue.textContent = (this as HTMLInputElement).value + '+';
  });

  // Quick genre filters
  quickFilters.forEach(button => {
    button.addEventListener('click', function(this: HTMLButtonElement) {
      const genre = (this as HTMLButtonElement).dataset.genre;
      if (genre === 'Todos') {
        // Reset genre filter
        const genreFilterEl = document.getElementById('genreFilter');
        if (genreFilterEl) (genreFilterEl as HTMLSelectElement).value = '';
      } else {
        // Set genre filter
        const genreFilterEl = document.getElementById('genreFilter');
if (genreFilterEl) (genreFilterEl as HTMLSelectElement).value = genre || '';
      }
      filterBooks();
      
      // Update active state
      quickFilters.forEach(btn => btn.classList.remove('bg-primary-500/30', 'text-primary-300'));
      (this as HTMLButtonElement).classList.add('bg-primary-500/30', 'text-primary-300');

    });
  });

  // Availability filters
  availabilityFilters.forEach(button => {
    button.addEventListener('click', function(this: HTMLButtonElement) {
      availabilityFilters.forEach((btn) => (btn as HTMLButtonElement).classList.remove('bg-primary-500/30', 'text-primary-300'));
      this.classList.add('bg-primary-500/30', 'text-primary-300');
      filterBooks();
    });
  });

  // Apply filters
  applyFilters?.addEventListener('click', function() {
    filterBooks();
    filterDropdown?.classList.add('hidden');
    const arrow = filterToggle?.querySelector('svg');
    arrow?.classList.remove('rotate-180');
  });

  // Clear filters
  clearFilters?.addEventListener('click', function() {
    const genreFilterEl = document.getElementById('genreFilter');
    if (genreFilterEl) (genreFilterEl as HTMLSelectElement).value = '';
    if (ratingFilter) (ratingFilter as HTMLInputElement).value = '0';
    if (ratingValue) (ratingValue as HTMLElement).textContent = '0+';
    availabilityFilters.forEach(btn => btn.classList.remove('bg-primary-500/30', 'text-primary-300'));
    availabilityFilters[1]?.classList.add('bg-primary-500/30', 'text-primary-300'); // Select "Todos"
    filterBooks();
  });

  // Filter books function
  function filterBooks() {
    const searchTerm = (searchInput as HTMLInputElement)?.value.toLowerCase() || '';
    const selectedGenre = (document.getElementById('genreFilter') as HTMLSelectElement)?.value || null;
    const minRating = parseFloat((ratingFilter as HTMLInputElement)?.value || '0') || 0;
    
    // Get availability filter state
    let onlyAvailable = false;
    availabilityFilters.forEach(button => {
      if (button.classList.contains('bg-primary-500') && (button as HTMLElement).dataset.available === 'true') {
        onlyAvailable = true;
      }
    });

    const bookCards = document.querySelectorAll('.book-card');
    let visibleBooks = 0;

    bookCards.forEach(card => {
      const title = card.querySelector('h3')?.textContent.toLowerCase() || '';
      const author = card.querySelector('p.text-gray-300')?.textContent.toLowerCase() || '';
      const genreElement = card.querySelector('[class*="bg-primary-500"]');
      const genre = genreElement?.textContent.toLowerCase() || '';
      const ratingElement = card.querySelector('.text-white');
      const rating = parseFloat((ratingElement as HTMLElement)?.textContent || '0') || 0;
      const availableElement = card.querySelector('.text-green-400');
      const availableText = availableElement?.textContent || '';
      const available = parseInt(availableText.split('/')[0]) || 0;

      // Search filter
      const matchesSearch = searchTerm === '' || 
        title.includes(searchTerm) || 
        author.includes(searchTerm) || 
        genre.includes(searchTerm);

      // Genre filter
      const matchesGenre = !selectedGenre || genre.includes(selectedGenre.toLowerCase());

      // Rating filter
      const matchesRating = rating >= minRating;

      // Availability filter
      const matchesAvailability = !onlyAvailable || available > 0;

      // Show/hide book
      if (matchesSearch && matchesGenre && matchesRating && matchesAvailability) {
        (card as HTMLElement).style.display = 'block';
        visibleBooks++;
      } else {
        (card as HTMLElement).style.display = 'none';
      }
    });

    // Show "no results" message if needed
    const noResultsMsg = document.getElementById('noResults');
    if (visibleBooks === 0) {
      if (!noResultsMsg) {
        const msg = document.createElement('div');
        msg.id = 'noResults';
        msg.className = 'col-span-full text-center py-12';
        msg.innerHTML = `
          <div class="glass-card p-8 max-w-md mx-auto">
            <svg class="w-16 h-16 text-gray-400 mx-auto mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.746 0 3.332.477 4.5 1.253v13C19.832 18.477 18.246 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/>
            </svg>
            <h3 class="text-xl font-semibold text-white mb-2">No se encontraron libros</h3>
            <p class="text-gray-300">Intenta ajustar tus filtros o términos de búsqueda</p>
          </div>
        `;
        (document.querySelector('.grid') as HTMLElement).appendChild(msg);
      }
    } else if (noResultsMsg) {
      noResultsMsg.remove();
    }
  }

  // Initialize with all books visible
  filterBooks();
</script>