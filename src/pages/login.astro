---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Iniciar Sesión - Biblioteca Digital">
  <div class="min-h-screen flex items-center justify-center px-4 py-20">
    <div class="absolute inset-0 bg-gradient-to-br from-primary-900/20 to-secondary-900/20"></div>
    
    <div class="relative z-10 glass-card max-w-md w-full p-8 md:p-12">
      <div class="text-center mb-8">
        <div class="w-20 h-20 bg-gradient-to-r from-primary-500 to-secondary-500 rounded-full flex items-center justify-center mx-auto mb-4">
          <svg class="w-10 h-10 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.746 0 3.332.477 4.5 1.253v13C19.832 18.477 18.246 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"></path>
          </svg>
        </div>
        <h1 class="text-3xl font-display font-bold text-white mb-2">
          Bienvenido de Vuelta
        </h1>
        <p class="text-gray-300">
          Inicia sesión para acceder a tu biblioteca personal
        </p>
      </div>

      <form id="loginForm" class="space-y-6">
        <div class="space-y-2">
          <label for="email" class="block text-sm font-semibold text-gray-200 mb-3">
            Correo Electrónico
          </label>
          <div class="relative">
            <input
              type="email"
              id="email"
              class="input-glass w-full pl-12 py-1 rounded-md"
              placeholder="tu@email.com"
              required
            />
            <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
              <svg class="w-5 h-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 12a4 4 0 10-8 0 4 4 0 008 0zm0 0v1.5a2.5 2.5 0 005 0V12a9 9 0 10-9 9m4.5-1.206a8.959 8.959 0 01-4.5 1.207"/>
              </svg>
            </div>
          </div>
        </div>
        
        <div class="space-y-2">
          <label for="password" class="block text-sm font-semibold text-gray-200 mb-3">
            Contraseña
          </label>
          <div class="relative">
            <input
              type="password"
              id="password"
              class="input-glass w-full pl-12 py-1 rounded-md"
              placeholder="••••••••"
              required
            />
            <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
              <svg class="w-5 h-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/>
              </svg>
            </div>
          </div>
        </div>

        <div id="errorMessage" class="hidden bg-red-500/20 border border-red-500/30 rounded-lg p-3">
          <p class="text-red-300 text-sm"></p>
        </div>

        <div class="flex justify-center">
          <button
          type="submit"
          id="submitBtn"
          class="form-button rounded-md self-center p-3 py-2 text-lg font-medium bg-gradient-to-r from-primary-500 to-secondary-500 text-white
          hover:from-primary-600 hover:to-secondary-600 transition-colors duration-150"
        >
          Iniciar Sesión
        </button>
        </div>
      </form>

      <div class="mt-6 text-center">
        <p class="text-gray-300">
          ¿No tienes una cuenta?{' '}
          <a href="/register" class="text-primary-400 hover:text-primary-300 font-medium transition-colors">
            Regístrate aquí
          </a>
        </p>
      </div>
    </div>
  </div>

  <script>
    document.getElementById('loginForm')?.addEventListener('submit', async (e) => {
      e.preventDefault();
      const submitBtn = document.getElementById('submitBtn') as HTMLButtonElement;
      const errorDiv = document.getElementById('errorMessage') as HTMLDivElement;
      const errorText = errorDiv.querySelector('p') as HTMLParagraphElement;
      
      submitBtn.disabled = true;
      submitBtn.textContent = 'Iniciando Sesión...';
      errorDiv.classList.add('hidden');
      
      const email = (document.getElementById('email') as HTMLInputElement).value;
      const password = (document.getElementById('password') as HTMLInputElement).value;
      
      try {
        const response = await fetch('http://localhost:3000/api/iniciar-sesion', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
          },
          body: JSON.stringify({ correo: email, clave: password }),
        });
        
        const data = await response.json();
        
        if (data.token && data.usuario) {
          localStorage.setItem('token', data.token);
          localStorage.setItem('user', JSON.stringify(data.usuario));
          window.location.href = '/dashboard';
        } else {
          errorText.textContent = data.message || 'Error al iniciar sesión';
          errorDiv.classList.remove('hidden');
        }
      } catch (error) {
        errorText.textContent = 'Error de conexión. Por favor, intenta de nuevo.';
        errorDiv.classList.remove('hidden');
      } finally {
        submitBtn.disabled = false;
        submitBtn.textContent = 'Iniciar Sesión';
      }
    });
  </script>
</Layout>