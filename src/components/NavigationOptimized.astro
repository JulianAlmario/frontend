---
import { BookOpen, User, Menu } from 'lucide-astro';

export interface Props {
  currentPath?: string;
}

const { currentPath = '/' } = Astro.props;

const navItems = [
  { href: '/', label: 'Inicio', prefetch: true },
  { href: '/libros', label: 'Libros', prefetch: true },
  { href: '/reservas', label: 'Reservas', prefetch: false },
  { href: '/dashboard', label: 'Panel', prefetch: false }
];
---

<nav class="fixed top-0 left-0 right-0 z-50 bg-slate-900/80 backdrop-blur-lg border-b border-white/10" transition:persist>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16">
      <div class="flex items-center space-x-3">
        <a 
          href="/" 
          class="flex items-center space-x-2 transition-opacity hover:opacity-80"
          aria-label="Biblioteca Digital - Inicio"
        >
          <div class="w-8 h-8 bg-gradient-to-r from-primary-500 to-secondary-500 rounded-lg flex items-center justify-center">
            <BookOpen size={20} class="text-white" />
          </div>
          <span class="text-white font-bold text-xl">Biblioteca Digital</span>
        </a>
      </div>
      
      <div class="hidden md:flex items-center space-x-6">
        {navItems.map(item => (
          <a 
            href={item.href}
            class:list={[
              "transition-colors duration-200 relative group",
              currentPath === item.href 
                ? "text-white font-medium" 
                : "text-gray-300 hover:text-white"
            ]}
            data-astro-prefetch={item.prefetch ? 'viewport' : 'false'}
            aria-current={currentPath === item.href ? 'page' : undefined}
          >
            {item.label}
            <span class="absolute bottom-0 left-0 w-full h-0.5 bg-gradient-to-r from-primary-500 to-secondary-500 transform scale-x-0 group-hover:scale-x-100 transition-transform duration-200 origin-left"></span>
          </a>
        ))}
        
        <div id="auth-buttons" class="flex items-center space-x-3">
          <a 
            href="/login" 
            class="text-gray-100 bg-primary-500 px-3 py-2 rounded-lg hover:bg-primary-600 hover:text-white transition-all duration-200 transform hover:scale-105"
            data-astro-prefetch="viewport"
          >
            Iniciar Sesión
          </a>
          <a 
            href="/register" 
            class="text-gray-100 bg-secondary-500 px-3 py-2 rounded-lg hover:bg-secondary-600 hover:text-white transition-all duration-200 transform hover:scale-105"
            data-astro-prefetch="viewport"
          >
            Registrarse
          </a>
        </div>
        
        <div id="user-menu" class="hidden items-center space-x-4">
          <a 
            href="/dashboard" 
            class="flex items-center space-x-2 text-white bg-white/10 px-4 py-2 rounded-lg hover:bg-white/20 transition-all duration-200 transform hover:scale-105"
            data-astro-prefetch="false"
          >
            <User size={16} />
            <span id="user-name"></span>
          </a>
          <button 
            id="logout-btn"
            class="text-gray-300 hover:text-white transition-colors duration-200"
            aria-label="Cerrar sesión"
          >
            Cerrar Sesión
          </button>
        </div>
      </div>
      
      <!-- Mobile menu button -->
      <div class="md:hidden">
        <button 
          class="text-gray-300 hover:text-white transition-colors duration-200"
          onclick="document.getElementById('mobile-menu').classList.toggle('hidden')"
          aria-label="Menú móvil"
          aria-expanded="false"
        >
          <Menu size={24} />
        </button>
      </div>
    </div>
  </div>
  
  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden md:hidden bg-slate-900/90 backdrop-blur-lg border-t border-white/10">
    <div class="px-4 py-3 space-y-2">
      {navItems.map(item => (
        <a 
          href={item.href}
          class:list={[
            "block py-2 transition-colors duration-200",
            currentPath === item.href 
              ? "text-white font-medium" 
              : "text-gray-300 hover:text-white"
          ]}
          data-astro-prefetch={item.prefetch ? 'tap' : 'false'}
        >
          {item.label}
        </a>
      ))}
      
      <div id="mobile-auth" class="space-y-2 pt-2 border-t border-white/10">
        <a 
          href="/login" 
          class="block text-gray-300 hover:text-white transition-colors duration-200 py-2"
          data-astro-prefetch="tap"
        >
          Iniciar Sesión
        </a>
        <a 
          href="/register" 
          class="block text-gray-300 hover:text-white transition-colors duration-200 py-2"
          data-astro-prefetch="tap"
        >
          Registrarse
        </a>
      </div>
      
      <div id="mobile-user" class="hidden space-y-2 pt-2 border-t border-white/10">
        <a 
          href="/dashboard" 
          class="block text-white py-2 transition-colors duration-200"
          data-astro-prefetch="false"
        >
          Mi Panel
        </a>
        <button 
          id="mobile-logout" 
          class="block text-gray-300 hover:text-white transition-colors duration-200 py-2 w-full text-left"
        >
          Cerrar Sesión
        </button>
      </div>
    </div>
  </div>
</nav>

<script>
  // Check authentication status and update UI
  function updateAuthUI() {
    const token = localStorage.getItem('token');
    const userStr = localStorage.getItem('user');
    
    const authButtons = document.getElementById('auth-buttons');
    const userMenu = document.getElementById('user-menu');
    const mobileAuth = document.getElementById('mobile-auth');
    const mobileUser = document.getElementById('mobile-user');
    
    if (token && userStr) {
      try {
        const user = JSON.parse(userStr);
        
        // Show user menu, hide auth buttons
        authButtons?.classList.add('hidden');
        userMenu?.classList.remove('hidden');
        mobileAuth?.classList.add('hidden');
        mobileUser?.classList.remove('hidden');
        
        // Update user name
        const userNameElement = document.getElementById('user-name');
        if (userNameElement) {
          userNameElement.textContent = user.nombre || 'Usuario';
        }
      } catch (error) {
        // Invalid user data, show auth buttons
        authButtons?.classList.remove('hidden');
        userMenu?.classList.add('hidden');
        mobileAuth?.classList.remove('hidden');
        mobileUser?.classList.add('hidden');
      }
    } else {
      // No token, show auth buttons
      authButtons?.classList.remove('hidden');
      userMenu?.classList.add('hidden');
      mobileAuth?.classList.remove('hidden');
      mobileUser?.classList.add('hidden');
    }
  }

  // Logout functionality
  function logout() {
    localStorage.removeItem('token');
    localStorage.removeItem('user');
    updateAuthUI();
    // Use smooth navigation instead of hard redirect
    window.location.href = '/';
  }

  // Initialize on page load
  document.addEventListener('DOMContentLoaded', updateAuthUI);

  // Add logout event listeners
  document.getElementById('logout-btn')?.addEventListener('click', logout);
  document.getElementById('mobile-logout')?.addEventListener('click', logout);

  // Update on storage changes (login/logout from other tabs)
  window.addEventListener('storage', updateAuthUI);
  
  // Close mobile menu when clicking outside
  document.addEventListener('click', (e) => {
    const mobileMenu = document.getElementById('mobile-menu');
    const menuButton = document.querySelector('button[onclick*="mobile-menu"]');
    
    if (mobileMenu && !mobileMenu.contains(e.target as Node) && !menuButton?.contains(e.target as Node)) {
      mobileMenu.classList.add('hidden');
    }
  });
</script>