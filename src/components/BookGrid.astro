---
import { Book, Calendar, User, Star } from 'lucide-astro';

const books = [
  {
    id: 1,
    title: "Cien Años de Soledad",
    author: "Gabriel García Márquez",
    genre: "Realismo Mágico",
    rating: 4.8,
    available: 3,
    cover: "https://trae-api-us.mchost.guru/api/ide/v1/text_to_image?prompt=Magical%20realism%20book%20cover%20with%20vibrant%20colors%20tropical%20elements%20mystical%20atmosphere&image_size=portrait_4_3"
  },
  {
    id: 2,
    title: "1984",
    author: "George Orwell",
    genre: "Distopía",
    rating: 4.7,
    available: 5,
    cover: "https://trae-api-us.mchost.guru/api/ide/v1/text_to_image?prompt=Dystopian%20book%20cover%20dark%20futuristic%20minimalist%20design%20big%20brother%20theme&image_size=portrait_4_3"
  },
  {
    id: 3,
    title: "Don Quijote de la Mancha",
    author: "Miguel de Cervantes",
    genre: "Clásico",
    rating: 4.9,
    available: 2,
    cover: "https://trae-api-us.mchost.guru/api/ide/v1/text_to_image?prompt=Classic%20Spanish%20literature%20book%20cover%20knight%20windmill%20vintage%20style&image_size=portrait_4_3"
  },
  {
    id: 4,
    title: "La Sombra del Viento",
    author: "Carlos Ruiz Zafón",
    genre: "Misterio",
    rating: 4.6,
    available: 4,
    cover: "https://trae-api-us.mchost.guru/api/ide/v1/text_to_image?prompt=Mysterious%20gothic%20book%20cover%20Barcelona%20cemetery%20foggy%20atmospheric&image_size=portrait_4_3"
  },
  {
    id: 5,
    title: "El Alquimista",
    author: "Paulo Coelho",
    genre: "Ficción Filosófica",
    rating: 4.5,
    available: 6,
    cover: "https://trae-api-us.mchost.guru/api/ide/v1/text_to_image?prompt=Philosophical%20fiction%20book%20cover%20desert%20pyramids%20journey%20spiritual&image_size=portrait_4_3"
  },
  {
    id: 6,
    title: "Rayuela",
    author: "Julio Cortázar",
    genre: "Literatura Experimental",
    rating: 4.4,
    available: 1,
    cover: "https://trae-api-us.mchost.guru/api/ide/v1/text_to_image?prompt=Experimental%20literature%20book%20cover%20abstract%20surreal%20artistic%20design&image_size=portrait_4_3"
  }
];
---

<section class="py-20 px-4">
  <div class="max-w-7xl mx-auto">
    <div class="text-center mb-16">
      <h2 class="text-4xl md:text-5xl font-display font-bold text-white mb-4 drop-shadow-lg">
        Libros Destacados
      </h2>
      <p class="text-xl text-gray-300 max-w-3xl mx-auto">
        Descubre los títulos más populares y reservados de nuestra colección
      </p>
    </div>
    
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {books.map((book) => (
        <div class="book-card group">
          <div class="relative overflow-hidden rounded-xl mb-4">
            <img 
              src={book.cover} 
              alt={book.title}
              class="w-full h-64 object-cover group-hover:scale-110 transition-transform duration-300"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-black/60 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
          </div>
          
          <div class="space-y-3">
            <h3 class="text-xl font-semibold text-white group-hover:text-primary-300 transition-colors">
              {book.title}
            </h3>
            <p class="text-gray-300 text-sm">{book.author}</p>
            <div class="flex items-center justify-between">
              <span class="bg-primary-500/20 text-primary-300 px-3 py-1 rounded-full text-sm font-medium">
                {book.genre}
              </span>
              <div class="flex items-center space-x-1">
                <Star class="text-yellow-400 fill-current" size={16} />
                <span class="text-white text-sm">{book.rating}</span>
              </div>
            </div>
       g     <div class="flex items-center justify-between pt-3 border-t border-white/10">
              <div class="flex items-center space-x-2">
                <Calendar class="text-green-400" size={16} />
                <span class="text-green-400 text-sm">{book.available} disponibles</span>
              </div>
              <button class="bg-gradient-to-r from-secondary-500 to-accent-500 hover:from-secondary-600 hover:to-accent-600 text-white px-4 py-2 rounded-lg text-sm font-medium transition-all duration-300 transform hover:scale-105">
                Reservar
              </button>
            </div>
          </div>
        </div>
      ))}
    </div>
    
    <div class="text-center mt-12">
      <button class="form-button rounded-md self-center p-3 py-2 text-lg font-medium bg-gradient-to-r from-primary-500 to-secondary-500 text-white
          hover:from-primary-600 hover:to-secondary-600 transition-colors duration-150">
        Ver Todos los Libros
      </button>
    </div>
  </div>
</section>