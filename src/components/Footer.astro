---
import { BookOpen, Mail, Phone, MapPin, Facebook, Twitter, Instagram } from 'lucide-astro';
---

<footer class="bg-slate-900/90 backdrop-blur-lg border-t border-white/10 mt-20">
  <div class="max-w-7xl mx-auto px-4 py-12">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
      <!-- Brand -->
      <div class="space-y-4">
        <div class="flex items-center space-x-3">
          <div class="w-8 h-8 bg-gradient-to-r from-primary-500 to-secondary-500 rounded-lg flex items-center justify-center">
            <BookOpen size={20} class="text-white" />
          </div>
          <span class="text-white font-bold text-xl">Biblioteca Digital</span>
        </div>
        <p class="text-gray-300 text-sm leading-relaxed">
          Tu portal de conocimiento y aventuras literarias. Descubre, reserva y disfruta de nuestros libros desde cualquier lugar.
        </p>
        <div class="flex space-x-4">
          <button class="w-10 h-10 bg-white/10 hover:bg-white/20 rounded-lg flex items-center justify-center transition-colors">
            <Facebook size={18} class="text-gray-300" />
          </button>
          <button class="w-10 h-10 bg-white/10 hover:bg-white/20 rounded-lg flex items-center justify-center transition-colors">
            <Twitter size={18} class="text-gray-300" />
          </button>
          <button class="w-10 h-10 bg-white/10 hover:bg-white/20 rounded-lg flex items-center justify-center transition-colors">
            <Instagram size={18} class="text-gray-300" />
          </button>
        </div>
      </div>

      <!-- Quick Links -->
      <div class="space-y-4">
        <h3 class="text-white font-semibold text-lg">Enlaces Rápidos</h3>
        <ul class="space-y-2">
          <li><a href="/" class="text-gray-300 hover:text-white transition-colors text-sm">Inicio</a></li>
          <li><a href="/libros" class="text-gray-300 hover:text-white transition-colors text-sm">Catálogo</a></li>
          <li><a href="#" class="text-gray-300 hover:text-white transition-colors text-sm">Reservas</a></li>
          <li><a href="#" class="text-gray-300 hover:text-white transition-colors text-sm">Mi Cuenta</a></li>
          <li><a href="#" class="text-gray-300 hover:text-white transition-colors text-sm">Ayuda</a></li>
        </ul>
      </div>

      <!-- Categories -->
      <div class="space-y-4">
        <h3 class="text-white font-semibold text-lg">Categorías Populares</h3>
        <ul class="space-y-2">
          <li><a href="#" class="text-gray-300 hover:text-white transition-colors text-sm">Ficción</a></li>
          <li><a href="#" class="text-gray-300 hover:text-white transition-colors text-sm">No Ficción</a></li>
          <li><a href="#" class="text-gray-300 hover:text-white transition-colors text-sm">Ciencia</a></li>
          <li><a href="#" class="text-gray-300 hover:text-white transition-colors text-sm">Historia</a></li>
          <li><a href="#" class="text-gray-300 hover:text-white transition-colors text-sm">Tecnología</a></li>
        </ul>
      </div>

      <!-- Contact -->
      <div class="space-y-4">
        <h3 class="text-white font-semibold text-lg">Contacto</h3>
        <div class="space-y-3">
          <div class="flex items-center space-x-3">
            <Mail size={16} class="text-gray-300" />
            <span class="text-gray-300 text-sm">info@bibliotecadigital.com</span>
          </div>
          <div class="flex items-center space-x-3">
            <Phone size={16} class="text-gray-300" />
            <span class="text-gray-300 text-sm">+1 (555) 123-4567</span>
          </div>
          <div class="flex items-center space-x-3">
            <MapPin size={16} class="text-gray-300" />
            <span class="text-gray-300 text-sm">Ciudad de México, México</span>
          </div>
        </div>
      </div>
    </div>

    <div class="border-t border-white/10 mt-8 pt-8 text-center">
      <p class="text-gray-300 text-sm">
        © 2024 Biblioteca Digital. Todos los derechos reservados.
      </p>
    </div>
  </div>
</footer>