---
export interface Props {
  showTransition?: boolean;
}

const { showTransition = true } = Astro.props;
---

<div class="page-transition-wrapper" data-transition-wrapper>
  <slot />
</div>

{showTransition && (
  <div class="transition-overlay" id="transition-overlay">
    <div class="transition-content">
      <div class="spinner"></div>
      <p class="transition-text">Cargando página...</p>
    </div>
  </div>
)}

<style>
  .page-transition-wrapper {
    position: relative;
    min-height: 100vh;
  }

  .transition-overlay {
    position: fixed;
    top: 0;
    left: 0;
    width: 100vw;
    height: 100vh;
    background: rgba(255, 255, 255, 0.95);
    backdrop-filter: blur(4px);
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 9999;
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.3s ease, visibility 0.3s ease;
  }

  .transition-overlay.active {
    opacity: 1;
    visibility: visible;
  }

  .transition-content {
    text-align: center;
    padding: 2rem;
  }

  .spinner {
    width: 40px;
    height: 40px;
    border: 4px solid #e5e7eb;
    border-top: 4px solid #3b82f6;
    border-radius: 50%;
    animation: spin 1s linear infinite;
    margin: 0 auto 1rem;
  }

  .transition-text {
    color: #6b7280;
    font-size: 0.875rem;
    font-weight: 500;
  }

  @keyframes spin {
    to {
      transform: rotate(360deg);
    }
  }

  /* View transition animations */
  ::view-transition-old(root) {
    animation: slideOut 0.3s ease-out forwards;
  }

  ::view-transition-new(root) {
    animation: slideIn 0.3s ease-out forwards;
  }

  @keyframes slideOut {
    from {
      transform: translateX(0);
      opacity: 1;
    }
    to {
      transform: translateX(-20px);
      opacity: 0;
    }
  }

  @keyframes slideIn {
    from {
      transform: translateX(20px);
      opacity: 0;
    }
    to {
      transform: translateX(0);
      opacity: 1;
    }
  }

  /* Reduced motion preferences */
  @media (prefers-reduced-motion: reduce) {
    ::view-transition-old(root),
    ::view-transition-new(root) {
      animation-duration: 0.1s;
    }
    
    .transition-overlay {
      transition-duration: 0.1s;
    }
  }
</style>

<script>
  // Show transition overlay during navigation
  document.addEventListener('astro:before-swap', () => {
    const overlay = document.getElementById('transition-overlay');
    if (overlay) {
      overlay.classList.add('active');
    }
  });

  // Hide transition overlay after navigation completes
  document.addEventListener('astro:after-swap', () => {
    const overlay = document.getElementById('transition-overlay');
    if (overlay) {
      setTimeout(() => {
        overlay.classList.remove('active');
      }, 100);
    }
  });

  // Fallback for browsers without view transitions
  if (!document.startViewTransition) {
    document.addEventListener('click', (e) => {
      const link = (e.target as HTMLElement).closest('a[href]');
      if (link && link.getAttribute('href')?.startsWith('/')) {
        const overlay = document.getElementById('transition-overlay');
        if (overlay) {
          overlay.classList.add('active');
        }
      }
    });
  }
</script>